{
  "name": "lazarus",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "node dev-with-qr.mjs",
    "dev:no-network": "next dev",
    "build": "next build",
    "start": "next start",
    "start:prod": "next start -p ${PORT:-3000}",
    "start-v0-specialist": "tsx scripts/start-v0-specialist.ts",
    "start-sqlite-specialist": "tsx scripts/start-sqlite-specialist.ts",
    "qa": "pnpm run lint && pnpm run type-check && pnpm run test",
    "qa:fix": "pnpm run lint:fix && pnpm run format",
    "qa:full": "pnpm run qa:fix && pnpm run test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "precommit": "lint-staged",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,css,scss,md,json,html}\" --config .prettierrc",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,css,scss,md,json,html}\" --config .prettierrc",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "clean": "rm -rf .next node_modules coverage",
    "clean:cache": "rm -rf .next node_modules/.cache",
    "reset": "pnpm run clean && rm -f pnpm-lock.yaml && pnpm store prune && pnpm install",
    "deps:check": "pnpm dlx npm-check-updates",
    "deps:update": "pnpm dlx npm-check-updates -u && pnpm install"
  },
