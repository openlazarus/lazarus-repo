# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Application URLs
NEXT_PUBLIC_API_URL=https://api.your-domain.com              # Legacy — kept for backward compat
NEXT_PUBLIC_LAZARUS_API_URL=https://api.your-domain.com      # Orchestrator (workspace list, billing, templates)
NEXT_PUBLIC_WORKSPACE_API_URL=http://localhost:8000           # Dev only — full URL override for per-workspace lazarus-api
NEXT_PUBLIC_WORKSPACE_BASE_DOMAIN=your-domain.com            # Prod base domain; workspaceId is prepended as subdomain
NEXT_PUBLIC_APP_URL=https://app.your-domain.com

# Feature Flags
# Set to 'true' to use mock data instead of real database
# Set to 'false' or remove to use real Supabase database
NEXT_PUBLIC_USE_MOCK_DATA=false

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Discord Integration
# Get these from https://discord.com/developers/applications
NEXT_PUBLIC_DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/callback/discord

# Sentry
NEXT_PUBLIC_SENTRY_DSN=

# Slack Integration
# Get these from https://api.slack.com/apps
NEXT_PUBLIC_SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_REDIRECT_URI=http://localhost:3000/api/auth/callback/slack