{
  "name": "lazarus-ts",
  "version": "1.0.0",
  "description": "Lazarus TypeScript Implementation - Institutional Memory System",
  "private": true,
  "main": "dist/index.js",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "precommit": "lint-staged",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "dev": "tsx -r tsconfig-paths/register src/index.ts",
    "clean": "rm -rf dist",
    "build": "rm -rf dist && tsc -p tsconfig.json && tsc-alias -p tsconfig.json && echo 'Build complete'",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "test:init": "tsx scripts/test-init.ts",
    "test:client": "tsx scripts/test-client.ts",
    "test:setup": "pnpm run test:init && pnpm run dev",
    "test:all": "pnpm run test:init && pnpm run test:client",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:agents": "jest __tests__/agents",
    "test:integration": "./scripts/test.sh",
    "test:quick": "./scripts/test-quick.sh"
  },
  "keywords": [
    "discord",
    "memory",
    "claude",
    "mcp"
  ],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.39",
    "@anthropic-ai/sdk": "^0.20.0",
    "@aws-sdk/client-s3": "^3.922.0",
    "@aws-sdk/client-ses": "^3.922.0",
    "@aws-sdk/credential-providers": "^3.1036.0",
    "@aws-sdk/s3-request-presigner": "^3.922.0",
    "@benborla29/mcp-server-mysql": "^2.0.8",
    "@deepgram/sdk": "^5.0.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^1.38.0",
    "@kapso/whatsapp-cloud-api": "^0.1.1",
    "@modelcontextprotocol/sdk": "^1.17.4",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-trace-node": "^2.7.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@prisma/client": "^5.11.0",
    "@sentry/node": "^10.38.0",
    "@slack/web-api": "^7.8.0",
    "@supabase/supabase-js": "^2.76.0",
    "@types/cors": "^2.8.17",
    "@types/multer": "^2.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/node-fetch": "^2.6.13",
    "@types/sqlite3": "^5.1.0",
    "@types/uuid": "^10.0.0",
    "agent-browser": "^0.14.0",
    "axios": "^1.11.0",
    "better-sqlite3": "^12.4.1",
    "chokidar": "^4.0.3",
    "cors": "^2.8.5",
    "cron-validator": "^1.4.0",
    "discord-interactions": "^4.4.0",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.2.0",
    "ioredis": "^5.10.1",
    "lucide-react": "^0.294.0",
    "mailparser": "^3.7.5",
    "multer": "^2.0.2",
    "nanoid": "^5.1.6",
    "node-cron": "^4.2.1",
    "node-fetch": "^2.7.0",
    "officeparser": "^6.1.1",
    "pg": "^8.17.2",
    "pino": "^10.3.0",
    "pino-http": "^11.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.8.0",
    "sqlite3": "^5.1.7",
    "uuid": "^11.1.0",
    "v0-sdk": "^0.14.0",
    "ws": "^8.18.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@evilmartians/lefthook": "^2.1.5",
    "@jest/globals": "^30.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^7.3.1",
    "@typescript-eslint/parser": "^7.3.1",
    "eslint": "^8.57.0",
    "jest": "^30.2.0",
    "lint-staged": "^16.4.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.2",
    "prisma": "^5.11.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.4",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.7.1",
    "typescript": "^5.4.3"
  }
}
