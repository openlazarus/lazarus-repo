# Lazarus TypeScript Backend Configuration
# Copy this file to .env and fill in your values

# Environment (production/development)
NODE_ENV=production

# Storage path (where workspace data is persisted; default: /mnt/sdc/storage)
# STORAGE_BASE_PATH=/var/lib/lazarus/storage

# API Configuration
API_PORT=8000
API_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# Email domain used to construct agent inbox addresses
# (e.g. EMAIL_DOMAIN=mail.example.com -> {agent}@{slug}.mail.example.com).
# Required if you enable any email integration. Falling back to the placeholder
# value here will cause outbound mail to fail.
EMAIL_DOMAIN=your-domain.example

# Optional: path to the analytics-mcp Python binary. Defaults to PATH lookup.
# Override only if you installed analytics-mcp somewhere not on $PATH.
# ANALYTICS_MCP_BIN=/usr/local/bin/analytics-mcp

# Public URLs (used for building links in emails, webhooks, OAuth callbacks)
# Defaults to localhost in dev; set to production URLs when deploying.
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
PUBLIC_API_URL=http://localhost:8000
LAZARUS_API_URL=http://localhost:8000

# Anthropic API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Default Configuration (optional)
DEFAULT_USER_ID=your_default_user_id
DEFAULT_WORKSPACE_ID=your_default_workspace_id

# Agent Configuration (optional)
AUTO_START_AGENTS=true
LIBRARIAN_POLL_INTERVAL=300000
LIBRARIAN_DISCOVERY_INTERVAL=3600000
AGENT_POLL_INTERVAL=5000

# Development Only - DO NOT USE IN PRODUCTION
# FORCE_ALL_PERMISSIONS=false
